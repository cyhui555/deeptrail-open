DEEPTRAIL_SERVER_IMAGE=registry.example.com/deeptrail-server@sha256:<digest>
DEEPTRAIL_WEB_IMAGE=registry.example.com/deeptrail-web@sha256:<digest>
DEEPTRAIL_RELEASE_ID=20260717-120000-<commit>
DEEPTRAIL_GIT_COMMIT=<40-character-commit>
DEEPTRAIL_SERVER_ARTIFACT_DIGEST=sha256:<digest>
DEEPTRAIL_SERVER_ENV_FILE=/etc/deeptrail/server.env
DEEPTRAIL_WEB_ENV_FILE=/etc/deeptrail/web.env
DEEPTRAIL_DATA_ROOT=/srv/deeptrail/data
DEEPTRAIL_LOG_ROOT=/srv/deeptrail/log
DEEPTRAIL_BACKUP_ROOT=/srv/deeptrail/backups
DEEPTRAIL_WEB_BIND=0.0.0.0
DEEPTRAIL_WEB_PORT=30301
DEEPTRAIL_PUBLIC_ORIGIN=http://deeptrail.example.invalid:30301
DEEPTRAIL_COOKIE_SECURE=false
DEEPTRAIL_MANAGEMENT_ENDPOINTS=health,info,prometheus
