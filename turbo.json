{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "target/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": ["target/surefire-reports/**"]
    },
    "typecheck": {
      "outputs": ["target/classes/**", "*.tsbuildinfo"]
    }
  }
}
