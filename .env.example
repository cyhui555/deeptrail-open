# Spring AI / LongCat OpenAI-compatible Provider
# 正式运行必须填写真实 Provider Key；local-mock-key/local-e2e-key 仅供 test Profile 使用。
SPRING_AI_OPENAI_API_KEY=replace-with-your-provider-key
SPRING_AI_OPENAI_BASE_URL=https://api.longcat.chat/openai
SPRING_AI_OPENAI_MODEL=LongCat-2.0

# 认证：每个部署环境必须使用至少 32 个随机字节
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRATION_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

# 可选：留空时禁用高德 Provider，并使用已配置的降级策略
GAODE_API_KEY=

# 高德地图：Web 服务 Key 仅供 Next.js 服务端代理使用；Web 端 Key 与安全密钥会进入浏览器包
AMAP_REST_KEY=
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# 使用逗号分隔的精确 Origin，不允许通配符
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# 可选：workspace 路径与容器内后端地址
APP_DATA_DIR=../../data
APP_LOG_DIR=../../log
BACKEND_INTERNAL_URL=http://server:8080
